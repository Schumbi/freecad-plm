# Kopieren nach .env und Werte vor dem Serverstart anpassen.

DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,plm.example.local
DJANGO_CSRF_TRUSTED_ORIGINS=https://plm.example.local
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
PLM_LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO
DJANGO_DB_LOG_LEVEL=WARNING
GUNICORN_LOG_LEVEL=info
GUNICORN_ACCESS_LOG=1

POSTGRES_DB=freecad_plm
POSTGRES_USER=freecad_plm
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_PORT=5432

PLM_HTTP_PORT=8000
PLM_IMAGE=registry.example.local/freecad-plm:latest
PLM_USER=plm
PLM_UID=1000
PLM_GID=1000
FREECADCMD_COMMAND=freecadcmd
PREVIEW_PNG_WIDTH=400
PREVIEW_PNG_HEIGHT=300
PROCESS_EXPORT_JOBS_INLINE=0
